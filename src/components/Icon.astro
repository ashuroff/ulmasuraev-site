---
interface Props {
  name:
    | "instagram"
    | "youtube"
    | "telegram"
    | "imdb"
    | "mail"
    | "phone"
    | "pin"
    | "play"
    | "arrow-right"
    | "trophy";
  class?: string;
}

const { name, class: className = "w-5 h-5" } = Astro.props;
---

{
  name === "instagram" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class={className}>
      <rect x="3" y="3" width="18" height="18" rx="5" />
      <circle cx="12" cy="12" r="4" />
      <circle cx="17.2" cy="6.8" r="1" fill="currentColor" stroke="none" />
    </svg>
  )
}
{
  name === "youtube" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class={className}>
      <rect x="2.5" y="5.5" width="19" height="13" rx="4" />
      <path d="M10.5 9.5l5 2.5-5 2.5z" fill="currentColor" stroke="none" />
    </svg>
  )
}
{
  name === "telegram" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class={className}>
      <circle cx="12" cy="12" r="9.5" />
      <path d="M6.5 12.2l11-4.4-2 9.7-3.6-2.6-2 1.9-.4-3.3 6.5-5.5-8 3.8z" stroke-linejoin="round" />
    </svg>
  )
}
{
  name === "imdb" && (
    <svg viewBox="0 0 24 24" class={className}>
      <rect x="1" y="6" width="22" height="12" rx="2" fill="#f5c518" />
      <text
        x="12"
        y="15.2"
        text-anchor="middle"
        font-family="Arial Black, Arial, sans-serif"
        font-weight="900"
        font-size="7"
        fill="#000000"
      >IMDb</text>
    </svg>
  )
}
{
  name === "mail" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class={className}>
      <rect x="3" y="5.5" width="18" height="13" rx="2" />
      <path d="M4 7l8 6 8-6" />
    </svg>
  )
}
{
  name === "phone" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class={className}>
      <path d="M6.5 4.5c.8 1.6 1.8 3 3 4.2l-1.6 2.1c1.3 2.4 3.3 4.4 5.7 5.7l2.1-1.6c1.2 1.2 2.6 2.2 4.2 3v2.5c0 1-.9 1.7-1.8 1.5-7-1.4-12.6-7-14-14-.2-.9.5-1.8 1.5-1.8h2.4z" />
    </svg>
  )
}
{
  name === "pin" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class={className}>
      <path d="M12 21s-7-6.4-7-11.5a7 7 0 1114 0C19 14.6 12 21 12 21z" />
      <circle cx="12" cy="9.5" r="2.4" />
    </svg>
  )
}
{
  name === "play" && (
    <svg viewBox="0 0 24 24" fill="currentColor" class={className}>
      <path d="M8 5.5v13l11-6.5z" />
    </svg>
  )
}
{
  name === "arrow-right" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class={className}>
      <path d="M4 12h16M14 6l6 6-6 6" />
    </svg>
  )
}
{
  name === "trophy" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" class={className}>
      <path d="M7 4h10v4a5 5 0 01-10 0V4z" />
      <path d="M7 5H4v2a3 3 0 003 3M17 5h3v2a3 3 0 01-3 3" />
      <path d="M12 13v3M9 20h6M9 18.5h6V20H9z" />
    </svg>
  )
}
