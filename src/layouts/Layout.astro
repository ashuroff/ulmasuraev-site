---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Ulmas Uraev — Actor · Theatre · Film",
  description = "Ulmas Uraev is an actor and director based in Tashkent with over ten years of professional stage and screen experience. Netflix · Uzbekfilm · Turon Theatre.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Inter:wght@400;500&family=Montserrat:wght@500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-ink text-primary antialiased">
    <slot />
  </body>
</html>
